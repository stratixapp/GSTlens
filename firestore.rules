rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Bills subcollection — full CRUD for owner only
      match /bills/{billId} {
        allow read, list: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.keys().hasAll(['total'])
          && request.resource.data.total is number
          && request.resource.data.total >= 0;
        allow update, delete: if request.auth != null && request.auth.uid == uid;
      }

      // Clients subcollection (Accountant Mode)
      match /clients/{clientId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
